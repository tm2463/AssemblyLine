manifest {
    name = 'my-pipeline'
    author = 'Tom Morrison'
    description = 'A short description'
    version = '0.1.0'
    nextflowVersion = '>=23.04.0'
}

params {
    input  = null
    outdir = "./results"

    help = false
    publish_dir_mode = 'copy'

    // fastp qc options
    min_depth = 30
    lower_assembly_length = 5500000

    // sylph options
    sylph_db = "/Users/tommorrison/Desktop/pipeline/databases/gtdb-r232-c1000-dbv1.syldb"
}

profiles {
    docker {
        docker.enabled = true
        docker.runOptions = '--platform linux/amd64'
        singularity.enabled = false
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        docker.enabled = false
    }

    conda {
        conda.enabled = true
    }
}

process {
    // Default resources
    cpus = 2
    memory = '4.GB'
    time = '2.h'

    // Resource labels
    withLabel: small {
        cpus = 1
        memory = '1.GB'
        time = '1.h'
    }

    withLabel: medium {
        cpus = 4
        memory = '8.GB'
        time = '4.h'
    }

    withLabel: large {
        cpus = 16
        memory = '32.GB'
        time = '12.h'
    }

    withLabel: extra_large {
        cpus = 32
        memory = '64.GB'
        time = '24.h'
    }
}
